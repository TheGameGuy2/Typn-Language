



###
This programm calculates fibonaci numbers
count is used for the loop, it represents the ammount of numbers to be calculated
###

###
int:count = 1

//Storing the last 2 numbers, functions WIP, arrays WIP
int:one = 0
int:two = 1

while(count<=(count*count/count - (0-0+1-1+count) + 1)) //doing some conditions tests
{
    
    count = count + 1

    int:temp = one

    one = two
    two = two + temp
    
}
